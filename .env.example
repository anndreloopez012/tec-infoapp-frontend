# Native features
VITE_NATIVE_PUSH_NOTIFICATIONS=true
VITE_NATIVE_CAMERA=true
VITE_NATIVE_GEOLOCATION=true

# Web Push (PWA / navegador en background)
# Pega aquí la clave pública VAPID del backend
VITE_VAPID_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"

# Importante:
# Las notificaciones push nativas de Android/iOS no usan variables Vite.
# Se configuran con los archivos de Firebase:
# - android/app/google-services.json
# - ios/App/App/GoogleService-Info.plist
